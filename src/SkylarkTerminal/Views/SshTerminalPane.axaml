<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:terminal="using:Iciclecreek.Terminal"
             xmlns:terminalFork="using:Iciclecreek.Avalonia.Terminal.Fork"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:models="using:SkylarkTerminal.Models"
             x:Class="SkylarkTerminal.Views.SshTerminalPane">
    <Grid RowDefinitions="Auto,*">
        <ui:InfoBar x:Name="SessionInfoBar"
                    Grid.Row="0"
                    IsOpen="False"
                    IsClosable="False"
                    Severity="Warning"
                    Title="Terminal Session">
            <ui:InfoBar.ActionButton>
                <Button Content="Reconnect"
                        Click="OnReconnectClick"/>
            </ui:InfoBar.ActionButton>
        </ui:InfoBar>

        <Grid Grid.Row="1">
            <terminalFork:RowStripedTerminalView x:Name="TerminalHost"
                                                 Process=""
                                                 Focusable="True"
                                                 FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                                                 FontSize="13"
                                                 Background="{DynamicResource Terminal.Background}"
                                                 Foreground="{DynamicResource Terminal.Foreground.Primary}">
                <terminalFork:RowStripedTerminalView.ContextFlyout>
                    <ui:FAMenuFlyout>
                        <ui:MenuFlyoutItem Text="Copy"
                                          Click="OnCopyClick"/>
                        <ui:MenuFlyoutItem Text="Paste"
                                          Click="OnPasteClick"/>
                        <ui:MenuFlyoutItem Text="Clear Screen"
                                          Click="OnClearClick"/>
                        <ui:MenuFlyoutSeparator/>
                        <ui:MenuFlyoutItem Text="Reconnect"
                                          Click="OnReconnectClick"/>
                    </ui:FAMenuFlyout>
                </terminalFork:RowStripedTerminalView.ContextFlyout>
            </terminalFork:RowStripedTerminalView>

            <Border x:Name="QuickStartOverlay"
                    IsVisible="False"
                    Background="{DynamicResource Terminal.Background}"
                    Padding="34,24,34,22">
                <Grid RowDefinitions="Auto,Auto,*"
                      RowSpacing="16">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Quick Start"
                                   FontSize="30"
                                   FontStyle="Italic"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Terminal.Foreground.Primary}"/>
                        <TextBlock x:Name="QuickStartText"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Terminal.Foreground.Primary}"
                                   Opacity="0.88"
                                   FontSize="13"
                                   Text="选择最近连接，或从左侧 Hosts 资产快速打开 SSH 会话。"/>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10">
                        <Border Grid.Column="0"
                                BorderBrush="{DynamicResource Terminal.Overlay.PanelBorder}"
                                BorderThickness="1"
                                CornerRadius="9"
                                Background="{DynamicResource Terminal.Overlay.PanelBackground}"
                                Padding="10,6">
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8">
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="13"
                                           Text="&#xE721;"
                                           Opacity="0.8"
                                           Foreground="{DynamicResource Terminal.Foreground.Primary}"/>
                                <TextBox x:Name="QuickStartSearchBox"
                                         Grid.Column="1"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Watermark="搜索最近连接"
                                         FontSize="13"
                                         TextChanged="OnQuickStartSearchTextChanged"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8">
                            <Button MinWidth="40"
                                    Height="36"
                                    Padding="10,0"
                                    Background="{DynamicResource Terminal.Overlay.PanelBackground}"
                                    BorderBrush="{DynamicResource Terminal.Overlay.PanelBorder}"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    ToolTip.Tip="定位到 Hosts 资产"
                                    Click="OnQuickStartBrowseHostsClick">
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="13"
                                           Foreground="{DynamicResource Terminal.Foreground.Primary}"
                                           Text="&#xE8A5;"/>
                            </Button>
                            <Button MinWidth="40"
                                    Height="36"
                                    Padding="10,0"
                                    Background="{DynamicResource Terminal.Overlay.PanelBackground}"
                                    BorderBrush="{DynamicResource Terminal.Overlay.PanelBorder}"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    ToolTip.Tip="新建标签"
                                    Click="OnQuickStartNewTabClick">
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="13"
                                           Foreground="{DynamicResource Terminal.Foreground.Primary}"
                                           Text="&#xE710;"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="2"
                                  Margin="0,2,0,0"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <ItemsControl x:Name="QuickStartRecentItems">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="models:QuickStartRecentConnection">
                                        <Button Width="212"
                                                MinHeight="128"
                                                Margin="0,0,14,14"
                                                Padding="14,12"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch"
                                                Background="{DynamicResource Terminal.Overlay.CardBackground}"
                                                BorderBrush="{DynamicResource Terminal.Overlay.CardBorder}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Foreground="{DynamicResource Terminal.Foreground.Primary}"
                                                Click="OnQuickStartConnectionClick">
                                            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                                  RowSpacing="6">
                                                <Border Width="30"
                                                        Height="30"
                                                        CornerRadius="15"
                                                        HorizontalAlignment="Left"
                                                        Background="{DynamicResource Terminal.Overlay.PanelBorder}">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                               FontSize="13"
                                                               Text="&#xE756;"/>
                                                </Border>
                                                <TextBlock Grid.Row="1"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding DisplayName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="180"/>
                                                <TextBlock Grid.Row="2"
                                                           FontSize="12"
                                                           Opacity="0.84"
                                                           Foreground="{DynamicResource Terminal.Foreground.Muted}"
                                                           Text="{Binding EndpointLabel}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="180"/>
                                                <TextBlock Grid.Row="3"
                                                           FontSize="11"
                                                           Opacity="0.62"
                                                           Foreground="{DynamicResource Terminal.Foreground.Muted}"
                                                           Text="{Binding LastUsedLabel}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="180"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border x:Name="QuickStartEmptyState"
                                    IsVisible="False"
                                    Margin="0,36,0,0"
                                    Padding="24,20"
                                    HorizontalAlignment="Left"
                                    BorderBrush="{DynamicResource Terminal.Overlay.CardBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Background="{DynamicResource Terminal.Overlay.CardBackground}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="暂无最近连接"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Terminal.Foreground.Primary}"/>
                                    <TextBlock Text="双击左侧 Hosts 资产中的主机，首次连接后会自动出现在这里。"
                                               FontSize="12"
                                               Opacity="0.76"
                                               TextWrapping="Wrap"
                                               MaxWidth="330"
                                               Foreground="{DynamicResource Terminal.Foreground.Primary}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border x:Name="ConnectingOverlay"
                    Background="{DynamicResource Terminal.Overlay.Background}"
                    IsVisible="True">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">
                    <ui:ProgressRing x:Name="ConnectingRing"
                                     Width="32"
                                     Height="32"
                                     IsActive="True"/>
                    <TextBlock x:Name="ConnectingText"
                               Foreground="{DynamicResource Terminal.Foreground.Primary}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="Connecting..."
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
