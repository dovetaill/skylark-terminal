<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:SkylarkTerminal.Models"
             xmlns:vm="using:SkylarkTerminal.ViewModels"
             xmlns:rightHeaders="using:SkylarkTerminal.Views.RightHeaders"
             xmlns:rightModes="using:SkylarkTerminal.Views.RightModes"
             x:Class="SkylarkTerminal.Views.RightSidebarHostView"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.DataTemplates>
        <DataTemplate DataType="models:ActionStripRightPanelHeader">
            <rightHeaders:ActionStripHeaderView/>
        </DataTemplate>
        <DataTemplate DataType="models:SftpCommandBarRightPanelHeader">
            <rightHeaders:SftpCommandBarHeaderView/>
        </DataTemplate>
        <DataTemplate DataType="models:SnippetsRightToolsContent">
            <rightModes:SnippetsModeView/>
        </DataTemplate>
        <DataTemplate DataType="models:HistoryRightToolsContent">
            <rightModes:HistoryModeView/>
        </DataTemplate>
        <DataTemplate DataType="models:SftpRightToolsContent">
            <rightModes:SftpModeView/>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0"
                Padding="10,8,10,6"
                BorderBrush="{DynamicResource ShellDividerBrush}"
                BorderThickness="0,0,0,1">
            <ListBox ItemsSource="{Binding RightToolsModeItems}"
                     Classes="RightSidebarModeButton"
                     SelectionMode="Single"
                     SelectedItem="{Binding SelectedRightToolsModeItem}"
                     BorderThickness="0"
                     Background="Transparent">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="models:RightToolsModeItem">
                        <Border Padding="8,6"
                                ToolTip.Tip="{Binding TooltipZh}">
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Text="{Binding Glyph}"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Border Grid.Row="1"
                Padding="10,6"
                BorderBrush="{DynamicResource ShellDividerBrush}"
                BorderThickness="0,0,0,1">
            <ContentControl Content="{Binding ActiveRightHeader}"/>
        </Border>

        <TransitioningContentControl Grid.Row="2"
                                     Margin="0"
                                     Content="{Binding ActiveRightMode.ContentNode}"/>
    </Grid>
</UserControl>
