<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="RootWindow"
        xmlns:models="using:SkylarkTerminal.Models"
        xmlns:vm="using:SkylarkTerminal.ViewModels"
        xmlns:views="using:SkylarkTerminal.Views"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1440"
        d:DesignHeight="900"
        x:Class="SkylarkTerminal.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/skylark-logo.ico"
        Title="{Binding WindowTitle}"
        Width="1440"
        Height="900"
        MinWidth="1100"
        MinHeight="700"
        Background="{DynamicResource ShellWindowBackground}"
        TransparencyLevelHint="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="38">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <x:Double x:Key="TabViewItemMinHeight">30</x:Double>
            <x:Double x:Key="TabViewItemMinWidth">92</x:Double>
            <x:Double x:Key="TabViewItemMaxWidth">460</x:Double>
            <x:Double x:Key="FlyoutThemeMinWidth">220</x:Double>
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Dark">
                        <SolidColorBrush x:Key="ShellWindowBackground" Color="#FF1A1D24"/>
                        <SolidColorBrush x:Key="ShellTopBarBrush" Color="#FF1E222A"/>
                        <SolidColorBrush x:Key="ShellRailBrush" Color="#FF21262F"/>
                        <SolidColorBrush x:Key="ShellAssetsToolbarBrush" Color="#FF2A303A"/>
                        <SolidColorBrush x:Key="ShellAssetsHeaderSeparatorBrush" Color="#FF3A4250"/>
                        <SolidColorBrush x:Key="ShellAssetsBrush" Color="#FF282D36"/>
                        <SolidColorBrush x:Key="ShellWorkspaceBrush" Color="#FF171B22"/>
                        <SolidColorBrush x:Key="ShellToolsBrush" Color="#FF1F242D"/>
                        <SolidColorBrush x:Key="ShellPanelBrush" Color="#FF262B34"/>
                    <SolidColorBrush x:Key="ShellBorderBrush" Color="#FF323843"/>
                    <SolidColorBrush x:Key="ShellDividerBrush" Color="#FF2A313B"/>
                    <SolidColorBrush x:Key="ShellTabActiveBrush" Color="#FF2A303B"/>
                    <SolidColorBrush x:Key="ShellTabInactiveBrush" Color="#FF1C2129"/>
                    <SolidColorBrush x:Key="ShellTabSelectionBorderBrush" Color="#FFFFFFFF"/>
                    <SolidColorBrush x:Key="ShellTerminalBrush" Color="#FF10141A"/>
                </ResourceDictionary>
                    <ResourceDictionary x:Key="Light">
                        <SolidColorBrush x:Key="ShellWindowBackground" Color="#FFF2F4F7"/>
                        <SolidColorBrush x:Key="ShellTopBarBrush" Color="#FFF5F6F8"/>
                        <SolidColorBrush x:Key="ShellRailBrush" Color="#FFE8ECF1"/>
                        <SolidColorBrush x:Key="ShellAssetsToolbarBrush" Color="#FFE8EDF2"/>
                        <SolidColorBrush x:Key="ShellAssetsHeaderSeparatorBrush" Color="#FFD1D8E2"/>
                        <SolidColorBrush x:Key="ShellAssetsBrush" Color="#FFEEF1F4"/>
                        <SolidColorBrush x:Key="ShellWorkspaceBrush" Color="#FFFDFEFF"/>
                        <SolidColorBrush x:Key="ShellToolsBrush" Color="#FFF0F3F6"/>
                        <SolidColorBrush x:Key="ShellPanelBrush" Color="#FFF1F3F6"/>
                    <SolidColorBrush x:Key="ShellBorderBrush" Color="#FFD5DBE4"/>
                    <SolidColorBrush x:Key="ShellDividerBrush" Color="#FFE0E4EB"/>
                    <SolidColorBrush x:Key="ShellTabActiveBrush" Color="#FFE5EAF0"/>
                    <SolidColorBrush x:Key="ShellTabInactiveBrush" Color="#FFF2F5F8"/>
                    <SolidColorBrush x:Key="ShellTabSelectionBorderBrush" Color="#FF000000"/>
                    <SolidColorBrush x:Key="ShellTerminalBrush" Color="#FFFFFFFF"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.TitleBarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>
        <Style Selector="Button.TitleBarButton:pointerover">
            <Setter Property="Background" Value="#14000000"/>
        </Style>
        <Style Selector="Button.TitleBarButton:pressed">
            <Setter Property="Background" Value="#22000000"/>
        </Style>
        <Style Selector="ui|TabView">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ui|TabViewItem">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
        <Style Selector="ui|TabViewItem /template/ Border#TabContainerBorder">
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="ui|TabViewItem:selected /template/ Path#LeftRadiusRenderArc">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="ui|TabViewItem:selected /template/ Path#RightRadiusRenderArc">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="ui|TabViewItem:selected /template/ Path#SelectedBackgroundPath">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Button.WindowControlButton">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.WindowControlClose:pointerover">
            <Setter Property="Background" Value="#E81123"/>
        </Style>
        <Style Selector="Button.WindowControlClose:pressed">
            <Setter Property="Background" Value="#C50F1F"/>
        </Style>
        <Style Selector="GridSplitter.ShellColumnSplitter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="SizeWestEast"/>
            <Setter Property="ShowsPreview" Value="True"/>
        </Style>
        <Style Selector="GridSplitter.ShellColumnSplitter:pointerover">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="GridSplitter.ShellColumnSplitter:pressed">
            <Setter Property="Background" Value="#14000000"/>
        </Style>
        <Style Selector="Button.TabStripActionButton">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="6,2,8,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.TabStripActionButton:pointerover">
            <Setter Property="Background" Value="#14000000"/>
        </Style>
        <Style Selector="Button.TabStripActionButton:pressed">
            <Setter Property="Background" Value="#22000000"/>
        </Style>
    </Window.Styles>

    <Grid Background="{DynamicResource ShellWindowBackground}"
          RowDefinitions="38,*">
        <views:TopStatusBarView Grid.Row="0"
                                DataContext="{Binding TopStatusBar}"/>

        <Grid x:Name="MainContentGrid"
              Grid.Row="1"
              Margin="0"
              ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="0"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="{DynamicResource ShellRailBrush}"
                    BorderBrush="{DynamicResource ShellBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="0"
                    Padding="8">
                <StackPanel Spacing="8">
                    <Button Classes="TitleBarButton"
                            Command="{Binding ShowHostsAssetsCommand}"
                            ToolTip.Tip="Hosts 资产">
                        <TextBlock Text="🖥"/>
                    </Button>
                    <Button Classes="TitleBarButton"
                            Command="{Binding ShowKeysAssetsCommand}"
                            ToolTip.Tip="密钥资产">
                        <TextBlock Text="🔑"/>
                    </Button>
                    <Border Height="1"
                            Margin="0"
                            Background="{DynamicResource ShellDividerBrush}"/>
                    <Button Classes="TitleBarButton"
                            Command="{Binding ToggleLeftAssetsPaneCommand}"
                            ToolTip.Tip="{Binding LeftAssetsPaneToggleToolTip}">
                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Text="{Binding LeftAssetsPaneToggleGlyph}"/>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    IsVisible="{Binding IsAssetsPanelVisible}"
                    IsHitTestVisible="{Binding IsAssetsPanelVisible}"
                    Background="Transparent"
                    BorderBrush="{DynamicResource ShellBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="0">
                <Grid RowDefinitions="Auto,1,*">
                    <Border Grid.Row="0"
                            Background="{DynamicResource ShellAssetsToolbarBrush}"
                            Padding="10,6"
                            BorderBrush="{DynamicResource ShellDividerBrush}"
                            BorderThickness="0">
                        <Grid RowDefinitions="Auto,Auto"
                              RowSpacing="6">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Opacity="0.9"
                                           Text="资产列表"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="4">
                                    <Button Classes="TitleBarButton"
                                            x:Name="AssetsSearchToggleButton"
                                            MinWidth="26"
                                            MinHeight="26"
                                            Padding="0"
                                            Command="{Binding ToggleAssetsSearchCommand}"
                                            ToolTip.Tip="搜索资产">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="&#xE721;"/>
                                    </Button>
                                    <Button Classes="TitleBarButton"
                                            MinWidth="26"
                                            MinHeight="26"
                                            Padding="0"
                                            IsVisible="{Binding IsTreeViewMode}"
                                            Command="{Binding ToggleAssetsExpandCollapseCommand}"
                                            ToolTip.Tip="{Binding AssetsExpandCollapseToolTip}">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding AssetsExpandCollapseGlyph}"/>
                                    </Button>
                                    <Button Classes="TitleBarButton"
                                            MinWidth="26"
                                            MinHeight="26"
                                            Padding="0"
                                            ToolTip.Tip="创建资产">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="&#xE8FE;"/>
                                        <Button.Flyout>
                                            <ui:FAMenuFlyout Placement="Bottom">
                                                <ui:MenuFlyoutItem Text="新建文件夹"
                                                                   Command="{Binding CreateFolderAssetCommand}"/>
                                                <ui:MenuFlyoutItem Text="新建 SSH 连接"
                                                                   Command="{Binding CreateSshConnectionAssetCommand}"/>
                                            </ui:FAMenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                    <Button Classes="TitleBarButton"
                                            MinWidth="26"
                                            MinHeight="26"
                                            Padding="0"
                                            Command="{Binding ToggleAssetsViewModeCommand}"
                                            ToolTip.Tip="{Binding AssetsViewModeToolTip}">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding AssetsViewModeGlyph}"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1"
                                    IsVisible="{Binding IsAssetsSearchOpen}"
                                    Background="#12000000"
                                    BorderBrush="{DynamicResource ShellDividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="6,0">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8">
                                    <TextBlock VerticalAlignment="Center"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               Opacity="0.68"
                                               Text="&#xE721;"/>
                                    <TextBox x:Name="AssetsSearchTextBox"
                                             Grid.Column="1"
                                             MinHeight="26"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Watermark="{Binding AssetsSearchPlaceholder}"
                                             Text="{Binding AssetsSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             LostFocus="OnAssetsSearchBoxLostFocus"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1"
                            Background="{DynamicResource ShellAssetsHeaderSeparatorBrush}"/>
                    <Border Grid.Row="2"
                            Background="{DynamicResource ShellAssetsBrush}">
                        <Grid Margin="0">
                        <TreeView ItemsSource="{Binding CurrentAssetTree}"
                                  SelectedItem="{Binding SelectedAssetNode, Mode=TwoWay}"
                                  Background="Transparent"
                                  IsVisible="{Binding IsTreeViewMode}">
                            <TreeView.ContextFlyout>
                                <ui:FAMenuFlyout>
                                    <ui:MenuFlyoutItem Text="新建目录"
                                              Command="{Binding CreateFolderFromContextCommand}"
                                              IsVisible="{Binding IsGeneralAssetsPane}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="新建连接"
                                              Command="{Binding CreateConnectionFromContextCommand}"
                                              IsVisible="{Binding IsGeneralAssetsPane}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="新建密码"
                                              Command="{Binding CreatePasswordAssetCommand}"
                                              IsVisible="{Binding IsKeysAssetsPane}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="新建密钥文件"
                                              Command="{Binding CreateKeyFileAssetCommand}"
                                              IsVisible="{Binding IsKeysAssetsPane}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="导入资产"
                                              Command="{Binding ImportAssetsCommand}"
                                              IsVisible="{Binding IsGeneralAssetsPane}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="导入密钥文件"
                                              Command="{Binding ImportAssetsCommand}"
                                              IsVisible="{Binding IsKeysAssetsPane}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutSeparator/>
                                    <ui:MenuFlyoutItem Text="粘贴"
                                              Command="{Binding PasteAssetCommand}"
                                              IsEnabled="{Binding HasAssetClipboardData}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="导出资产"
                                              Command="{Binding ExportAssetsCommand}"
                                              IsVisible="{Binding IsGeneralAssetsPane}"
                                              IsEnabled="False"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="导出密钥"
                                              Command="{Binding ExportAssetsCommand}"
                                              IsVisible="{Binding IsKeysAssetsPane}"
                                              IsEnabled="False"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutSeparator/>
                                    <ui:MenuFlyoutItem Text="刷新"
                                              Command="{Binding RefreshAssetsCommand}"
                                              CommandParameter="{x:Null}"/>
                                </ui:FAMenuFlyout>
                            </TreeView.ContextFlyout>
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem"
                                       x:DataType="models:AssetNode">
                                    <Setter Property="IsExpanded"
                                            Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="IsVisible"
                                            Value="{Binding IsVisible}"/>
                                    <Setter Property="HorizontalAlignment"
                                            Value="Stretch"/>
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate DataType="models:AssetNode"
                                                  ItemsSource="{Binding Children}">
                                    <Border Background="Transparent"
                                            HorizontalAlignment="Stretch"
                                            DoubleTapped="OnAssetNodeDoubleTapped"
                                            Padding="2,0">
                                        <Border.ContextFlyout>
                                            <ui:FAMenuFlyout>
                                                <ui:MenuFlyoutItem Text="新建目录"
                                                          Command="{Binding $parent[Window].DataContext.CreateFolderFromContextCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsGeneralAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="新建连接"
                                                          Command="{Binding $parent[Window].DataContext.CreateConnectionFromContextCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsGeneralAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="新建密码"
                                                          Command="{Binding $parent[Window].DataContext.CreatePasswordAssetCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsKeysAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="新建密钥文件"
                                                          Command="{Binding $parent[Window].DataContext.CreateKeyFileAssetCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsKeysAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="导入资产"
                                                          Command="{Binding $parent[Window].DataContext.ImportAssetsCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsGeneralAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="导入密钥文件"
                                                          Command="{Binding $parent[Window].DataContext.ImportAssetsCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsKeysAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutSeparator/>
                                                <ui:MenuFlyoutItem Text="在新标签打开"
                                                          Command="{Binding $parent[Window].DataContext.OpenAssetInNewTabCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsGeneralAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="复制"
                                                          Command="{Binding $parent[Window].DataContext.CopyAssetCommand}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="剪切"
                                                          Command="{Binding $parent[Window].DataContext.CutAssetCommand}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="粘贴"
                                                          Command="{Binding $parent[Window].DataContext.PasteAssetCommand}"
                                                          IsEnabled="{Binding $parent[Window].DataContext.HasAssetClipboardData}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutSeparator/>
                                                <ui:MenuFlyoutItem Text="删除"
                                                          Command="{Binding $parent[Window].DataContext.DeleteAssetCommand}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="克隆"
                                                          Command="{Binding $parent[Window].DataContext.CloneAssetCommand}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="重命名"
                                                          Command="{Binding $parent[Window].DataContext.RenameAssetCommand}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutSeparator/>
                                                <ui:MenuFlyoutItem Text="导出资产"
                                                          Command="{Binding $parent[Window].DataContext.ExportAssetsCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsGeneralAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="导出密钥"
                                                          Command="{Binding $parent[Window].DataContext.ExportAssetsCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsKeysAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="刷新"
                                                          Command="{Binding $parent[Window].DataContext.RefreshAssetsCommand}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutSeparator/>
                                                <ui:MenuFlyoutItem Text="复制Host"
                                                          Command="{Binding $parent[Window].DataContext.CopyHostCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsGeneralAssetsPane}"
                                                          IsEnabled="{Binding IsConnection}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                            </ui:FAMenuFlyout>
                                        </Border.ContextFlyout>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <TextBlock Text="{Binding AssetTypeIcon}"/>
                                            <Grid MinWidth="160">
                                                <TextBlock Text="{Binding Name}"
                                                           IsVisible="{Binding IsDisplayNameVisible}"/>
                                                <TextBox IsVisible="{Binding IsRenaming}"
                                                         Text="{Binding EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         BorderThickness="1"
                                                         Padding="4,0"
                                                         MinHeight="24"
                                                         KeyDown="OnAssetRenameTextBoxKeyDown"
                                                         LostFocus="OnAssetRenameTextBoxLostFocus"
                                                         AttachedToVisualTree="OnAssetRenameTextBoxAttachedToVisualTree"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>

                        <ListBox x:Name="AssetsFlatListBox"
                                 ItemsSource="{Binding CurrentAssetFlatList}"
                                 SelectedItem="{Binding SelectedAssetNode, Mode=TwoWay}"
                                 Background="Transparent"
                                 SelectionMode="Multiple"
                                 SelectionChanged="OnFlatAssetSelectionChanged"
                                 PointerPressed="OnAssetsFlatListPointerPressed"
                                 PointerMoved="OnAssetsFlatListPointerMoved"
                                 PointerReleased="OnAssetsFlatListPointerReleased"
                                 IsVisible="{Binding IsFlatViewMode}">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment"
                                            Value="Stretch"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ContextFlyout>
                                <ui:FAMenuFlyout>
                                    <ui:MenuFlyoutItem Text="新建目录"
                                              Command="{Binding CreateFolderFromContextCommand}"
                                              IsVisible="{Binding IsGeneralAssetsPane}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="新建连接"
                                              Command="{Binding CreateConnectionFromContextCommand}"
                                              IsVisible="{Binding IsGeneralAssetsPane}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="新建密码"
                                              Command="{Binding CreatePasswordAssetCommand}"
                                              IsVisible="{Binding IsKeysAssetsPane}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="新建密钥文件"
                                              Command="{Binding CreateKeyFileAssetCommand}"
                                              IsVisible="{Binding IsKeysAssetsPane}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="导入资产"
                                              Command="{Binding ImportAssetsCommand}"
                                              IsVisible="{Binding IsGeneralAssetsPane}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="导入密钥文件"
                                              Command="{Binding ImportAssetsCommand}"
                                              IsVisible="{Binding IsKeysAssetsPane}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutSeparator/>
                                    <ui:MenuFlyoutItem Text="粘贴"
                                              Command="{Binding PasteAssetCommand}"
                                              IsEnabled="{Binding HasAssetClipboardData}"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="导出资产"
                                              Command="{Binding ExportAssetsCommand}"
                                              IsVisible="{Binding IsGeneralAssetsPane}"
                                              IsEnabled="False"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutItem Text="导出密钥"
                                              Command="{Binding ExportAssetsCommand}"
                                              IsVisible="{Binding IsKeysAssetsPane}"
                                              IsEnabled="False"
                                              CommandParameter="{x:Null}"/>
                                    <ui:MenuFlyoutSeparator/>
                                    <ui:MenuFlyoutItem Text="刷新"
                                              Command="{Binding RefreshAssetsCommand}"
                                              CommandParameter="{x:Null}"/>
                                </ui:FAMenuFlyout>
                            </ListBox.ContextFlyout>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="models:AssetNode">
                                    <Border Background="Transparent"
                                            HorizontalAlignment="Stretch"
                                            PointerPressed="OnAssetListItemPointerPressed"
                                            DoubleTapped="OnAssetNodeDoubleTapped"
                                            Padding="2,0">
                                        <Border.ContextFlyout>
                                            <ui:FAMenuFlyout>
                                                <ui:MenuFlyoutItem Text="新建目录"
                                                          Command="{Binding $parent[Window].DataContext.CreateFolderFromContextCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsGeneralAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="新建连接"
                                                          Command="{Binding $parent[Window].DataContext.CreateConnectionFromContextCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsGeneralAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="新建密码"
                                                          Command="{Binding $parent[Window].DataContext.CreatePasswordAssetCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsKeysAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="新建密钥文件"
                                                          Command="{Binding $parent[Window].DataContext.CreateKeyFileAssetCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsKeysAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="导入资产"
                                                          Command="{Binding $parent[Window].DataContext.ImportAssetsCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsGeneralAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="导入密钥文件"
                                                          Command="{Binding $parent[Window].DataContext.ImportAssetsCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsKeysAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutSeparator/>
                                                <ui:MenuFlyoutItem Text="在新标签打开"
                                                          Command="{Binding $parent[Window].DataContext.OpenAssetInNewTabCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsGeneralAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="复制"
                                                          Command="{Binding $parent[Window].DataContext.CopyAssetCommand}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="剪切"
                                                          Command="{Binding $parent[Window].DataContext.CutAssetCommand}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="粘贴"
                                                          Command="{Binding $parent[Window].DataContext.PasteAssetCommand}"
                                                          IsEnabled="{Binding $parent[Window].DataContext.HasAssetClipboardData}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutSeparator/>
                                                <ui:MenuFlyoutItem Text="删除"
                                                          Command="{Binding $parent[Window].DataContext.DeleteAssetCommand}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="克隆"
                                                          Command="{Binding $parent[Window].DataContext.CloneAssetCommand}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="重命名"
                                                          Command="{Binding $parent[Window].DataContext.RenameAssetCommand}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutSeparator/>
                                                <ui:MenuFlyoutItem Text="导出资产"
                                                          Command="{Binding $parent[Window].DataContext.ExportAssetsCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsGeneralAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="导出密钥"
                                                          Command="{Binding $parent[Window].DataContext.ExportAssetsCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsKeysAssetsPane}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutItem Text="刷新"
                                                          Command="{Binding $parent[Window].DataContext.RefreshAssetsCommand}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                                <ui:MenuFlyoutSeparator/>
                                                <ui:MenuFlyoutItem Text="复制Host"
                                                          Command="{Binding $parent[Window].DataContext.CopyHostCommand}"
                                                          IsVisible="{Binding $parent[Window].DataContext.IsGeneralAssetsPane}"
                                                          IsEnabled="{Binding IsConnection}"
                                                          CommandParameter="{Binding}">
                                                </ui:MenuFlyoutItem>
                                            </ui:FAMenuFlyout>
                                        </Border.ContextFlyout>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <TextBlock Text="{Binding AssetTypeIcon}"/>
                                            <Grid MinWidth="160">
                                                <TextBlock Text="{Binding Name}"
                                                           IsVisible="{Binding IsDisplayNameVisible}"/>
                                                <TextBox IsVisible="{Binding IsRenaming}"
                                                         Text="{Binding EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         BorderThickness="1"
                                                         Padding="4,0"
                                                         MinHeight="24"
                                                         KeyDown="OnAssetRenameTextBoxKeyDown"
                                                         LostFocus="OnAssetRenameTextBoxLostFocus"
                                                         AttachedToVisualTree="OnAssetRenameTextBoxAttachedToVisualTree"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Canvas IsHitTestVisible="False"
                                IsVisible="{Binding IsFlatViewMode}">
                            <Border x:Name="AssetsSelectionMarquee"
                                    IsVisible="False"
                                    Width="0"
                                    Height="0"
                                    Background="#163B82F6"
                                    BorderBrush="#8A3B82F6"
                                    BorderThickness="1"
                                    CornerRadius="2"/>
                        </Canvas>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="2"
                          Classes="ShellColumnSplitter"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          IsVisible="{Binding IsAssetsPanelVisible}"
                          IsHitTestVisible="{Binding IsAssetsPanelVisible}"
                          PointerReleased="OnAssetsPanelSplitterPointerReleased"/>

            <Border Grid.Column="3"
                    Background="{DynamicResource ShellWorkspaceBrush}"
                    BorderBrush="{DynamicResource ShellBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="0">
                <Border.ContextFlyout>
                    <ui:FAMenuFlyout>
                        <ui:MenuFlyoutItem Text="新建标签"
                                  Command="{Binding CreateWorkspaceTabCommand}"/>
                        <ui:MenuFlyoutItem Text="关闭当前标签"
                                  Command="{Binding CloseTabCommand}"
                                  CommandParameter="{x:Null}"/>
                        <ui:MenuFlyoutSeparator/>
                        <ui:MenuFlyoutItem Text="关闭其他标签"
                                  Command="{Binding CloseOtherTabsCommand}"
                                  CommandParameter="{x:Null}"/>
                        <ui:MenuFlyoutItem Text="关闭全部标签"
                                  Command="{Binding CloseAllTabsCommand}"/>
                        <ui:MenuFlyoutSeparator/>
                        <ui:MenuFlyoutItem Text="显示 Snippets"
                                  Command="{Binding ShowSnippetsToolsCommand}"/>
                        <ui:MenuFlyoutItem Text="显示 History"
                                  Command="{Binding ShowHistoryToolsCommand}"/>
                        <ui:MenuFlyoutItem Text="显示 SFTP"
                                  Command="{Binding ShowSftpToolsCommand}"/>
                    </ui:FAMenuFlyout>
                </Border.ContextFlyout>
                <ui:TabView TabItems="{Binding Tabs}"
                            SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                            Margin="0"
                            Padding="0"
                            Background="Transparent"
                            IsAddTabButtonVisible="False"
                            TabWidthMode="SizeToContent"
                            CanReorderTabs="True"
                            CanDragTabs="True"
                            CloseButtonOverlayMode="OnPointerOver"
                            TabCloseRequested="OnWorkspaceTabCloseRequested">
                    <ui:TabView.ContextFlyout>
                        <ui:FAMenuFlyout>
                            <ui:MenuFlyoutItem Text="新建标签"
                                      Command="{Binding CreateWorkspaceTabCommand}"/>
                            <ui:MenuFlyoutItem Text="关闭当前标签"
                                      Command="{Binding CloseTabCommand}"
                                      CommandParameter="{x:Null}"/>
                            <ui:MenuFlyoutSeparator/>
                            <ui:MenuFlyoutItem Text="关闭其他标签"
                                      Command="{Binding CloseOtherTabsCommand}"
                                      CommandParameter="{x:Null}"/>
                            <ui:MenuFlyoutItem Text="关闭全部标签"
                                      Command="{Binding CloseAllTabsCommand}"/>
                            <ui:MenuFlyoutSeparator/>
                            <ui:MenuFlyoutItem Text="显示 Snippets"
                                      Command="{Binding ShowSnippetsToolsCommand}"/>
                            <ui:MenuFlyoutItem Text="显示 History"
                                      Command="{Binding ShowHistoryToolsCommand}"/>
                            <ui:MenuFlyoutItem Text="显示 SFTP"
                                      Command="{Binding ShowSftpToolsCommand}"/>
                        </ui:FAMenuFlyout>
                    </ui:TabView.ContextFlyout>
                    <ui:TabView.TabStripFooter>
                        <Button Classes="TabStripActionButton"
                                Command="{Binding CreateWorkspaceTabCommand}"
                                ToolTip.Tip="新建标签">
                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="&#xE710;"/>
                        </Button>
                    </ui:TabView.TabStripFooter>
                    <ui:TabView.TabItemTemplate>
                        <DataTemplate DataType="vm:WorkspaceTabItemViewModel">
                            <ui:TabViewItem IsClosable="True">
                                <ui:TabViewItem.Header>
                                    <Border Margin="0"
                                            Height="28"
                                            Padding="10,0,8,0"
                                            CornerRadius="0"
                                            ClipToBounds="True"
                                            Background="{Binding HeaderBackgroundBrush}"
                                            BorderBrush="{DynamicResource ShellTabSelectionBorderBrush}"
                                            BorderThickness="{Binding HeaderBottomBorderThickness}">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Spacing="5">
                                            <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Opacity="{Binding HeaderOpacity}"
                                                       Text="&#xE756;"/>
                                            <TextBlock FontWeight="{Binding HeaderFontWeight}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Opacity="{Binding HeaderOpacity}"
                                                       Text="{Binding Header}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"
                                                       MaxWidth="420"/>
                                        </StackPanel>
                                    </Border>
                                </ui:TabViewItem.Header>
                                <ui:TabViewItem.ContextFlyout>
                                    <ui:FAMenuFlyout>
                                        <ui:MenuFlyoutItem Text="Duplicate"
                                                  Tag="duplicate"
                                                  Click="OnWorkspaceTabContextActionClick"/>
                                        <ui:MenuFlyoutSeparator/>
                                        <ui:MenuFlyoutItem Text="Close"
                                                  Tag="close"
                                                  Click="OnWorkspaceTabContextActionClick"/>
                                        <ui:MenuFlyoutItem Text="Close Others"
                                                  Tag="close-others"
                                                  Click="OnWorkspaceTabContextActionClick"/>
                                        <ui:MenuFlyoutItem Text="Close Tabs To Left"
                                                  Tag="close-left"
                                                  Click="OnWorkspaceTabContextActionClick"/>
                                        <ui:MenuFlyoutItem Text="Close Tabs To Right"
                                                  Tag="close-right"
                                                  Click="OnWorkspaceTabContextActionClick"/>
                                        <ui:MenuFlyoutSeparator/>
                                        <ui:MenuFlyoutItem Text="Close All"
                                                  Tag="close-all"
                                                  Click="OnWorkspaceTabContextActionClick"/>
                                    </ui:FAMenuFlyout>
                                </ui:TabViewItem.ContextFlyout>
                                <Border Margin="0"
                                        CornerRadius="0"
                                        Background="{DynamicResource ShellTerminalBrush}">
                                    <Grid Margin="0"
                                          RowDefinitions="*">
                                        <Border Grid.Row="0"
                                                Margin="0"
                                                Padding="12,8"
                                                CornerRadius="0"
                                                Background="{DynamicResource ShellTerminalBrush}">
                                            <TextBlock FontFamily="Consolas"
                                                       FontSize="12"
                                                       Opacity="0.8"
                                                       Text="{Binding PlaceholderText}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </ui:TabViewItem>
                        </DataTemplate>
                    </ui:TabView.TabItemTemplate>
                </ui:TabView>
            </Border>

            <GridSplitter Grid.Column="4"
                          Classes="ShellColumnSplitter"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          PointerReleased="OnRightSidebarSplitterPointerReleased"
                          IsVisible="{Binding IsRightSidebarVisible}"
                          IsHitTestVisible="{Binding IsRightSidebarVisible}"/>

            <Border Grid.Column="5"
                    MinWidth="120"
                    IsVisible="{Binding IsRightSidebarVisible}"
                    Background="{DynamicResource ShellToolsBrush}"
                    BorderBrush="{DynamicResource ShellBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="0">
                <Border.ContextFlyout>
                    <ui:FAMenuFlyout>
                        <ui:MenuFlyoutItem Text="Snippet 视图"
                                  Command="{Binding ShowSnippetsToolsCommand}"/>
                        <ui:MenuFlyoutItem Text="History 视图"
                                  Command="{Binding ShowHistoryToolsCommand}"/>
                        <ui:MenuFlyoutItem Text="SFTP 视图"
                                  Command="{Binding ShowSftpToolsCommand}"/>
                        <ui:MenuFlyoutSeparator/>
                        <ui:MenuFlyoutItem Text="隐藏工具栏"
                                  Command="{Binding ToggleRightSidebarCommand}"/>
                    </ui:FAMenuFlyout>
                </Border.ContextFlyout>
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Padding="14,10"
                            BorderBrush="{DynamicResource ShellDividerBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="Tools Panel (E)"/>
                            <Button Classes="TitleBarButton"
                                    Command="{Binding ToggleRightSidebarCommand}"
                                    Content="Hide"/>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="1"
                          RowDefinitions="Auto,*"
                          Margin="0">
                        <Grid.ContextFlyout>
                            <ui:FAMenuFlyout>
                                <ui:MenuFlyoutItem Text="Snippet 视图"
                                          Command="{Binding ShowSnippetsToolsCommand}"/>
                                <ui:MenuFlyoutItem Text="History 视图"
                                          Command="{Binding ShowHistoryToolsCommand}"/>
                                <ui:MenuFlyoutItem Text="SFTP 视图"
                                          Command="{Binding ShowSftpToolsCommand}"/>
                                <ui:MenuFlyoutSeparator/>
                                <ui:MenuFlyoutItem Text="隐藏工具栏"
                                          Command="{Binding ToggleRightSidebarCommand}"/>
                            </ui:FAMenuFlyout>
                        </Grid.ContextFlyout>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <Button Classes="TitleBarButton"
                                    Command="{Binding ShowSnippetsToolsCommand}"
                                    Content="Snippet"/>
                            <Button Classes="TitleBarButton"
                                    Command="{Binding ShowHistoryToolsCommand}"
                                    Content="History"/>
                            <Button Classes="TitleBarButton"
                                    Command="{Binding ShowSftpToolsCommand}"
                                    Content="SFTP"/>
                        </StackPanel>

                        <Grid Grid.Row="1"
                              Margin="0">
                            <ListBox ItemsSource="{Binding SnippetItems}"
                                     IsVisible="{Binding IsSnippetsView}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="models:CommandSnippet">
                                        <StackPanel Margin="0"
                                                    Spacing="2">
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Name}"/>
                                            <TextBlock FontFamily="Consolas"
                                                       Opacity="0.86"
                                                       Text="{Binding Command}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <ListBox ItemsSource="{Binding HistoryItems}"
                                     IsVisible="{Binding IsHistoryView}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="models:CommandHistoryEntry">
                                        <Grid ColumnDefinitions="Auto,*"
                                              Margin="0">
                                            <TextBlock Opacity="0.72"
                                                       FontFamily="Consolas"
                                                       Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"/>
                                            <TextBlock Grid.Column="1"
                                                       Margin="4,0,0,0"
                                                       Text="{Binding Command}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <ListBox ItemsSource="{Binding SftpItems}"
                                     IsVisible="{Binding IsSftpView}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="models:RemoteFileNode">
                                        <Grid ColumnDefinitions="*,Auto"
                                              Margin="0">
                                            <TextBlock Text="{Binding Name}"/>
                                            <TextBlock Grid.Column="1"
                                                       Opacity="0.72"
                                                       Text="{Binding FullPath}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Window>
