<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="RootWindow"
        xmlns:models="using:SkylarkTerminal.Models"
        xmlns:vm="using:SkylarkTerminal.ViewModels"
        xmlns:views="using:SkylarkTerminal.Views"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1440"
        d:DesignHeight="900"
        x:Class="SkylarkTerminal.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/skylark-logo.ico"
        Title="{Binding WindowTitle}"
        Width="1440"
        Height="900"
        MinWidth="1100"
        MinHeight="700"
        Background="{DynamicResource ShellWindowBackground}"
        TransparencyLevelHint="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="38">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <ResourceDictionary>
            <x:Double x:Key="TabViewItemMinHeight">30</x:Double>
            <x:Double x:Key="TabViewItemMinWidth">92</x:Double>
            <x:Double x:Key="TabViewItemMaxWidth">460</x:Double>
            <x:Double x:Key="FlyoutThemeMinWidth">220</x:Double>
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Dark">
                        <SolidColorBrush x:Key="ShellWindowBackground" Color="#FF1A1D24"/>
                        <SolidColorBrush x:Key="ShellTopBarBrush" Color="#FF1E222A"/>
                        <SolidColorBrush x:Key="ShellRailBrush" Color="#FF21262F"/>
                        <SolidColorBrush x:Key="ShellAssetsToolbarBrush" Color="#FF2A303A"/>
                        <SolidColorBrush x:Key="ShellAssetsHeaderSeparatorBrush" Color="#FF3A4250"/>
                        <SolidColorBrush x:Key="ShellAssetsBrush" Color="#FF282D36"/>
                        <SolidColorBrush x:Key="ShellWorkspaceBrush" Color="#FF171B22"/>
                        <SolidColorBrush x:Key="ShellToolsBrush" Color="#FF1F242D"/>
                        <SolidColorBrush x:Key="ShellPanelBrush" Color="#FF262B34"/>
                    <SolidColorBrush x:Key="ShellBorderBrush" Color="#FF323843"/>
                    <SolidColorBrush x:Key="ShellDividerBrush" Color="#FF2A313B"/>
                    <SolidColorBrush x:Key="ShellTabActiveBrush" Color="#FF2A303B"/>
                    <SolidColorBrush x:Key="ShellTabInactiveBrush" Color="#FF1C2129"/>
                    <SolidColorBrush x:Key="ShellTabSelectionBorderBrush" Color="#FFFFFFFF"/>
                    <SolidColorBrush x:Key="Terminal.Background" Color="#FF10141A"/>
                    <SolidColorBrush x:Key="Terminal.Foreground.Primary" Color="#FFE6EDF7"/>
                    <SolidColorBrush x:Key="Terminal.Foreground.Muted" Color="#B8E6EDF7"/>
                    <SolidColorBrush x:Key="Terminal.RowStripe.Even" Color="#FF10141A"/>
                    <SolidColorBrush x:Key="Terminal.RowStripe.Odd" Color="#FF141A23"/>
                    <SolidColorBrush x:Key="Terminal.Selection" Color="#4D6EA8FE"/>
                    <SolidColorBrush x:Key="Terminal.Cursor" Color="#FFE6EDF7"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Keyword" Color="#FF87B6FF"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.String" Color="#FF98D89E"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Number" Color="#FFF6C177"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Path" Color="#FF80CBC4"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Error" Color="#FFFF7B72"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Warn" Color="#FFFFC857"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Success" Color="#FF6FD3A8"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Comment" Color="#FF8B9BB4"/>
                    <SolidColorBrush x:Key="Terminal.Overlay.Background" Color="#A010141A"/>
                    <SolidColorBrush x:Key="Terminal.Overlay.PanelBackground" Color="#12FFFFFF"/>
                    <SolidColorBrush x:Key="Terminal.Overlay.PanelBorder" Color="#26FFFFFF"/>
                    <SolidColorBrush x:Key="Terminal.Overlay.CardBackground" Color="#18FFFFFF"/>
                    <SolidColorBrush x:Key="Terminal.Overlay.CardBorder" Color="#26FFFFFF"/>
                    <SolidColorBrush x:Key="ShellTerminalBrush" Color="#FF10141A"/>
                    <SolidColorBrush x:Key="ShellTerminalPrimaryTextBrush" Color="#FFE6EDF7"/>
                    <SolidColorBrush x:Key="ShellTerminalAccentTextBrush" Color="#FF87B6FF"/>
                </ResourceDictionary>
                    <ResourceDictionary x:Key="Light">
                        <SolidColorBrush x:Key="ShellWindowBackground" Color="#FFF2F4F7"/>
                        <SolidColorBrush x:Key="ShellTopBarBrush" Color="#FFF5F6F8"/>
                        <SolidColorBrush x:Key="ShellRailBrush" Color="#FFE8ECF1"/>
                        <SolidColorBrush x:Key="ShellAssetsToolbarBrush" Color="#FFE8EDF2"/>
                        <SolidColorBrush x:Key="ShellAssetsHeaderSeparatorBrush" Color="#FFD1D8E2"/>
                        <SolidColorBrush x:Key="ShellAssetsBrush" Color="#FFEEF1F4"/>
                        <SolidColorBrush x:Key="ShellWorkspaceBrush" Color="#FFFDFEFF"/>
                        <SolidColorBrush x:Key="ShellToolsBrush" Color="#FFF0F3F6"/>
                        <SolidColorBrush x:Key="ShellPanelBrush" Color="#FFF1F3F6"/>
                    <SolidColorBrush x:Key="ShellBorderBrush" Color="#FFD5DBE4"/>
                    <SolidColorBrush x:Key="ShellDividerBrush" Color="#FFE0E4EB"/>
                    <SolidColorBrush x:Key="ShellTabActiveBrush" Color="#FFE5EAF0"/>
                    <SolidColorBrush x:Key="ShellTabInactiveBrush" Color="#FFF2F5F8"/>
                    <SolidColorBrush x:Key="ShellTabSelectionBorderBrush" Color="#FF000000"/>
                    <SolidColorBrush x:Key="Terminal.Background" Color="#FFFFFFFF"/>
                    <SolidColorBrush x:Key="Terminal.Foreground.Primary" Color="#FF1A1F27"/>
                    <SolidColorBrush x:Key="Terminal.Foreground.Muted" Color="#99222A33"/>
                    <SolidColorBrush x:Key="Terminal.RowStripe.Even" Color="#FFFFFFFF"/>
                    <SolidColorBrush x:Key="Terminal.RowStripe.Odd" Color="#FFF7F9FC"/>
                    <SolidColorBrush x:Key="Terminal.Selection" Color="#4D6EA8FE"/>
                    <SolidColorBrush x:Key="Terminal.Cursor" Color="#FF1A1F27"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Keyword" Color="#FF005A9C"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.String" Color="#FF2C7A3F"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Number" Color="#FF8A5A00"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Path" Color="#FF0D6E77"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Error" Color="#FFB42318"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Warn" Color="#FF9A6700"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Success" Color="#FF027A48"/>
                    <SolidColorBrush x:Key="Terminal.Syntax.Comment" Color="#FF6B7785"/>
                    <SolidColorBrush x:Key="Terminal.Overlay.Background" Color="#E6FFFFFF"/>
                    <SolidColorBrush x:Key="Terminal.Overlay.PanelBackground" Color="#0F1A1F27"/>
                    <SolidColorBrush x:Key="Terminal.Overlay.PanelBorder" Color="#221A1F27"/>
                    <SolidColorBrush x:Key="Terminal.Overlay.CardBackground" Color="#0A1A1F27"/>
                    <SolidColorBrush x:Key="Terminal.Overlay.CardBorder" Color="#1F1A1F27"/>
                    <SolidColorBrush x:Key="ShellTerminalBrush" Color="#FFFFFFFF"/>
                    <SolidColorBrush x:Key="ShellTerminalPrimaryTextBrush" Color="#FF1A1F27"/>
                    <SolidColorBrush x:Key="ShellTerminalAccentTextBrush" Color="#FF005A9C"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.TitleBarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>
        <Style Selector="Button.TitleBarButton:pointerover">
            <Setter Property="Background" Value="#14000000"/>
        </Style>
        <Style Selector="Button.TitleBarButton:pressed">
            <Setter Property="Background" Value="#22000000"/>
        </Style>
        <Style Selector="ui|TabView">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ui|TabViewItem">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
        <Style Selector="ui|TabViewItem /template/ Border#TabContainerBorder">
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="ui|TabViewItem:selected /template/ Path#LeftRadiusRenderArc">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="ui|TabViewItem:selected /template/ Path#RightRadiusRenderArc">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="ui|TabViewItem:selected /template/ Path#SelectedBackgroundPath">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Button.WindowControlButton">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.WindowControlClose:pointerover">
            <Setter Property="Background" Value="#E81123"/>
        </Style>
        <Style Selector="Button.WindowControlClose:pressed">
            <Setter Property="Background" Value="#C50F1F"/>
        </Style>
        <Style Selector="GridSplitter.ShellColumnSplitter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="SizeWestEast"/>
            <Setter Property="ShowsPreview" Value="True"/>
        </Style>
        <Style Selector="GridSplitter.ShellColumnSplitter:pointerover">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="GridSplitter.ShellColumnSplitter:pressed">
            <Setter Property="Background" Value="#14000000"/>
        </Style>
        <Style Selector="Button.TabStripActionButton">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="6,2,8,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.TabStripActionButton:pointerover">
            <Setter Property="Background" Value="#14000000"/>
        </Style>
        <Style Selector="Button.TabStripActionButton:pressed">
            <Setter Property="Background" Value="#22000000"/>
        </Style>
        <Style Selector="ui|FAMenuFlyoutPresenter.assets-tree-root-context-flyout">
            <Setter Property="Width" Value="232"/>
            <Setter Property="MinWidth" Value="232"/>
            <Setter Property="MaxWidth" Value="232"/>
        </Style>
        <Style Selector="ui|FAMenuFlyoutPresenter.assets-flat-root-context-flyout">
            <Setter Property="Width" Value="232"/>
            <Setter Property="MinWidth" Value="232"/>
            <Setter Property="MaxWidth" Value="232"/>
        </Style>
        <Style Selector="ui|FAMenuFlyoutPresenter.assets-tree-node-context-flyout">
            <Setter Property="Width" Value="240"/>
            <Setter Property="MinWidth" Value="240"/>
            <Setter Property="MaxWidth" Value="240"/>
        </Style>
        <Style Selector="ui|FAMenuFlyoutPresenter.assets-flat-node-context-flyout">
            <Setter Property="Width" Value="240"/>
            <Setter Property="MinWidth" Value="240"/>
            <Setter Property="MaxWidth" Value="240"/>
        </Style>
        <Style Selector="ui|FAMenuFlyoutPresenter.workspace-root-context-flyout">
            <Setter Property="Width" Value="232"/>
            <Setter Property="MinWidth" Value="232"/>
            <Setter Property="MaxWidth" Value="232"/>
        </Style>
        <Style Selector="ui|FAMenuFlyoutPresenter.workspace-tabstrip-context-flyout">
            <Setter Property="Width" Value="232"/>
            <Setter Property="MinWidth" Value="232"/>
            <Setter Property="MaxWidth" Value="232"/>
        </Style>
        <Style Selector="ui|FAMenuFlyoutPresenter.workspace-tabitem-context-flyout">
            <Setter Property="Width" Value="240"/>
            <Setter Property="MinWidth" Value="240"/>
            <Setter Property="MaxWidth" Value="240"/>
        </Style>
        <Style Selector="ui|FAMenuFlyoutPresenter.tools-root-context-flyout">
            <Setter Property="Width" Value="232"/>
            <Setter Property="MinWidth" Value="232"/>
            <Setter Property="MaxWidth" Value="232"/>
        </Style>
        <Style Selector="ui|FAMenuFlyoutPresenter.tools-grid-context-flyout">
            <Setter Property="Width" Value="232"/>
            <Setter Property="MinWidth" Value="232"/>
            <Setter Property="MaxWidth" Value="232"/>
        </Style>
        <Style Selector="ui|MenuFlyoutItem.AssetsContextTitleItem">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.86"/>
            <Setter Property="Padding" Value="16,10,10,8"/>
        </Style>
        <Style Selector="ui|MenuFlyoutItem.AssetsContextActionItem">
            <Setter Property="Padding" Value="16,9,10,9"/>
        </Style>
        <Style Selector="ui|MenuFlyoutItem.WorkspaceContextTitleItem">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.86"/>
            <Setter Property="Padding" Value="16,10,10,8"/>
        </Style>
        <Style Selector="ui|MenuFlyoutItem.WorkspaceContextActionItem">
            <Setter Property="Padding" Value="16,9,10,9"/>
        </Style>
        <Style Selector="ui|MenuFlyoutItem.ToolsContextTitleItem">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.86"/>
            <Setter Property="Padding" Value="16,10,10,8"/>
        </Style>
        <Style Selector="ui|MenuFlyoutItem.ToolsContextActionItem">
            <Setter Property="Padding" Value="16,9,10,9"/>
        </Style>
    </Window.Styles>

    <Grid Background="{DynamicResource ShellWindowBackground}"
          RowDefinitions="38,*">
        <views:TopStatusBarView Grid.Row="0"
                                DataContext="{Binding TopStatusBar}"/>

        <Grid x:Name="MainContentGrid"
              Grid.Row="1"
              Margin="0"
              ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="0"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="{DynamicResource ShellRailBrush}"
                    BorderBrush="{DynamicResource ShellBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="0"
                    Padding="8">
                <StackPanel Spacing="8">
                    <Button Classes="TitleBarButton"
                            Command="{Binding ShowHostsAssetsCommand}"
                            ToolTip.Tip="Hosts 资产">
                        <TextBlock Text="🖥"/>
                    </Button>
                    <Button Classes="TitleBarButton"
                            Command="{Binding ShowKeysAssetsCommand}"
                            ToolTip.Tip="密钥资产">
                        <TextBlock Text="🔑"/>
                    </Button>
                    <Border Height="1"
                            Margin="0"
                            Background="{DynamicResource ShellDividerBrush}"/>
                    <Button Classes="TitleBarButton"
                            Command="{Binding ToggleLeftAssetsPaneCommand}"
                            ToolTip.Tip="{Binding LeftAssetsPaneToggleToolTip}">
                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   Text="{Binding LeftAssetsPaneToggleGlyph}"/>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    IsVisible="{Binding IsAssetsPanelVisible}"
                    IsHitTestVisible="{Binding IsAssetsPanelVisible}"
                    Background="Transparent"
                    BorderBrush="{DynamicResource ShellBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="0">
                <Grid RowDefinitions="Auto,1,*">
                    <Border Grid.Row="0"
                            Background="{DynamicResource ShellAssetsToolbarBrush}"
                            Padding="10,6"
                            BorderBrush="{DynamicResource ShellDividerBrush}"
                            BorderThickness="0">
                        <Grid RowDefinitions="Auto,Auto"
                              RowSpacing="6">
                            <Grid Grid.Row="0"
                                  ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Opacity="0.9"
                                           Text="资产列表"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="4">
                                    <Button Classes="TitleBarButton"
                                            x:Name="AssetsSearchToggleButton"
                                            MinWidth="26"
                                            MinHeight="26"
                                            Padding="0"
                                            Command="{Binding ToggleAssetsSearchCommand}"
                                            ToolTip.Tip="搜索资产">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="&#xE721;"/>
                                    </Button>
                                    <Button Classes="TitleBarButton"
                                            MinWidth="26"
                                            MinHeight="26"
                                            Padding="0"
                                            IsVisible="{Binding IsTreeViewMode}"
                                            Command="{Binding ToggleAssetsExpandCollapseCommand}"
                                            ToolTip.Tip="{Binding AssetsExpandCollapseToolTip}">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding AssetsExpandCollapseGlyph}"/>
                                    </Button>
                                    <Button Classes="TitleBarButton"
                                            MinWidth="26"
                                            MinHeight="26"
                                            Padding="0"
                                            ToolTip.Tip="创建资产">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="&#xE8FE;"/>
                                        <Button.Flyout>
                                            <ui:FAMenuFlyout Placement="Bottom">
                                                <ui:MenuFlyoutItem Text="新建文件夹"
                                                                   Command="{Binding CreateFolderAssetCommand}"/>
                                                <ui:MenuFlyoutItem Text="新建 SSH 连接"
                                                                   Command="{Binding CreateSshConnectionAssetCommand}"/>
                                            </ui:FAMenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                    <Button Classes="TitleBarButton"
                                            MinWidth="26"
                                            MinHeight="26"
                                            Padding="0"
                                            Command="{Binding ToggleAssetsViewModeCommand}"
                                            ToolTip.Tip="{Binding AssetsViewModeToolTip}">
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding AssetsViewModeGlyph}"/>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1"
                                    IsVisible="{Binding IsAssetsSearchOpen}"
                                    Background="#12000000"
                                    BorderBrush="{DynamicResource ShellDividerBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="6,0">
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="8">
                                    <TextBlock VerticalAlignment="Center"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               Opacity="0.68"
                                               Text="&#xE721;"/>
                                    <TextBox x:Name="AssetsSearchTextBox"
                                             Grid.Column="1"
                                             MinHeight="26"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Watermark="{Binding AssetsSearchPlaceholder}"
                                             Text="{Binding AssetsSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             LostFocus="OnAssetsSearchBoxLostFocus"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1"
                            Background="{DynamicResource ShellAssetsHeaderSeparatorBrush}"/>
                    <Border Grid.Row="2"
                            Background="{DynamicResource ShellAssetsBrush}">
                        <Grid Margin="0">
                        <TreeView ItemsSource="{Binding CurrentAssetTree}"
                                  SelectedItem="{Binding SelectedAssetNode, Mode=TwoWay}"
                                  Background="Transparent"
                                  IsVisible="{Binding IsTreeViewMode}">
                            <TreeView.ContextFlyout>
                                <ui:FAMenuFlyout FlyoutPresenterClasses="assets-tree-root-context-flyout">
                                    <ui:MenuFlyoutItem Text="操作"
                                              IsEnabled="False"
                                              Classes="AssetsContextTitleItem"/>
                                    <ui:MenuFlyoutSeparator/>
                                    <ui:MenuFlyoutItem Text="新建目录"
                                              Classes="AssetsContextActionItem"
                                              Command="{Binding CreateFolderFromContextCommand}"
                                              IsVisible="{Binding IsGeneralAssetsPane}"
                                              CommandParameter="{x:Null}">
                                        <ui:MenuFlyoutItem.IconSource>
                                            <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE710;"/>
                                        </ui:MenuFlyoutItem.IconSource>
                                    </ui:MenuFlyoutItem>
                                    <ui:MenuFlyoutItem Text="新建连接"
                                              Classes="AssetsContextActionItem"
                                              Command="{Binding CreateConnectionFromContextCommand}"
                                              IsVisible="{Binding IsGeneralAssetsPane}"
                                              CommandParameter="{x:Null}">
                                        <ui:MenuFlyoutItem.IconSource>
                                            <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE71D;"/>
                                        </ui:MenuFlyoutItem.IconSource>
                                    </ui:MenuFlyoutItem>
                                    <ui:MenuFlyoutItem Text="新建密码"
                                              Classes="AssetsContextActionItem"
                                              Command="{Binding CreatePasswordAssetCommand}"
                                              IsVisible="{Binding IsKeysAssetsPane}"
                                              CommandParameter="{x:Null}">
                                        <ui:MenuFlyoutItem.IconSource>
                                            <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE72E;"/>
                                        </ui:MenuFlyoutItem.IconSource>
                                    </ui:MenuFlyoutItem>
                                    <ui:MenuFlyoutItem Text="新建密钥文件"
                                              Classes="AssetsContextActionItem"
                                              Command="{Binding CreateKeyFileAssetCommand}"
                                              IsVisible="{Binding IsKeysAssetsPane}"
                                              CommandParameter="{x:Null}">
                                        <ui:MenuFlyoutItem.IconSource>
                                            <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE8A5;"/>
                                        </ui:MenuFlyoutItem.IconSource>
                                    </ui:MenuFlyoutItem>
                                    <ui:MenuFlyoutItem Text="导入资产"
                                              Classes="AssetsContextActionItem"
                                              Command="{Binding ImportAssetsCommand}"
                                              IsVisible="{Binding IsGeneralAssetsPane}"
                                              CommandParameter="{x:Null}">
                                        <ui:MenuFlyoutItem.IconSource>
                                            <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE898;"/>
                                        </ui:MenuFlyoutItem.IconSource>
                                    </ui:MenuFlyoutItem>
                                    <ui:MenuFlyoutItem Text="导入密钥文件"
                                              Classes="AssetsContextActionItem"
                                              Command="{Binding ImportAssetsCommand}"
                                              IsVisible="{Binding IsKeysAssetsPane}"
                                              CommandParameter="{x:Null}">
                                        <ui:MenuFlyoutItem.IconSource>
                                            <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE898;"/>
                                        </ui:MenuFlyoutItem.IconSource>
                                    </ui:MenuFlyoutItem>
                                    <ui:MenuFlyoutSeparator/>
                                    <ui:MenuFlyoutItem Text="粘贴"
                                              Classes="AssetsContextActionItem"
                                              Command="{Binding PasteAssetCommand}"
                                              IsEnabled="{Binding HasAssetClipboardData}"
                                              CommandParameter="{x:Null}">
                                        <ui:MenuFlyoutItem.IconSource>
                                            <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE77F;"/>
                                        </ui:MenuFlyoutItem.IconSource>
                                    </ui:MenuFlyoutItem>
                                    <ui:MenuFlyoutItem Text="导出资产"
                                              Classes="AssetsContextActionItem"
                                              Command="{Binding ExportAssetsCommand}"
                                              IsVisible="{Binding IsGeneralAssetsPane}"
                                              IsEnabled="False"
                                              CommandParameter="{x:Null}">
                                        <ui:MenuFlyoutItem.IconSource>
                                            <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xEDE1;"/>
                                        </ui:MenuFlyoutItem.IconSource>
                                    </ui:MenuFlyoutItem>
                                    <ui:MenuFlyoutItem Text="导出密钥"
                                              Classes="AssetsContextActionItem"
                                              Command="{Binding ExportAssetsCommand}"
                                              IsVisible="{Binding IsKeysAssetsPane}"
                                              IsEnabled="False"
                                              CommandParameter="{x:Null}">
                                        <ui:MenuFlyoutItem.IconSource>
                                            <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xEDE1;"/>
                                        </ui:MenuFlyoutItem.IconSource>
                                    </ui:MenuFlyoutItem>
                                    <ui:MenuFlyoutSeparator/>
                                    <ui:MenuFlyoutItem Text="刷新"
                                              Classes="AssetsContextActionItem"
                                              Command="{Binding RefreshAssetsCommand}"
                                              CommandParameter="{x:Null}">
                                        <ui:MenuFlyoutItem.IconSource>
                                            <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE72C;"/>
                                        </ui:MenuFlyoutItem.IconSource>
                                    </ui:MenuFlyoutItem>
                                </ui:FAMenuFlyout>
                            </TreeView.ContextFlyout>
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem"
                                       x:DataType="models:AssetNode">
                                    <Setter Property="IsExpanded"
                                            Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="IsVisible"
                                            Value="{Binding IsVisible}"/>
                                    <Setter Property="HorizontalAlignment"
                                            Value="Stretch"/>
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate DataType="models:AssetNode"
