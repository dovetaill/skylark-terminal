                                                          IsEnabled="{Binding IsConnection}"
                                                          CommandParameter="{Binding}">
                                                    <ui:MenuFlyoutItem.IconSource>
                                                        <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE8C8;"/>
                                                    </ui:MenuFlyoutItem.IconSource>
                                                </ui:MenuFlyoutItem>
                                            </ui:FAMenuFlyout>
                                        </Border.ContextFlyout>
                                        <Grid>
                                            <Border IsHitTestVisible="False"
                                                    Background="#2A3B82F6"
                                                    CornerRadius="4"
                                                    Opacity="{Binding QuickLocateHighlightOpacity}">
                                                <Border.Transitions>
                                                    <Transitions>
                                                        <DoubleTransition Property="Opacity"
                                                                          Duration="0:0:0.20"/>
                                                    </Transitions>
                                                </Border.Transitions>
                                            </Border>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <TextBlock Text="{Binding AssetTypeIcon}"/>
                                                <Grid MinWidth="160">
                                                    <TextBlock Text="{Binding Name}"
                                                               IsVisible="{Binding IsDisplayNameVisible}"/>
                                                    <TextBox IsVisible="{Binding IsRenaming}"
                                                             Text="{Binding EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             BorderThickness="1"
                                                             Padding="4,0"
                                                             MinHeight="24"
                                                             KeyDown="OnAssetRenameTextBoxKeyDown"
                                                             LostFocus="OnAssetRenameTextBoxLostFocus"
                                                             AttachedToVisualTree="OnAssetRenameTextBoxAttachedToVisualTree"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Canvas IsHitTestVisible="False"
                                IsVisible="{Binding IsFlatViewMode}">
                            <Border x:Name="AssetsSelectionMarquee"
                                    IsVisible="False"
                                    Width="0"
                                    Height="0"
                                    Background="#163B82F6"
                                    BorderBrush="#8A3B82F6"
                                    BorderThickness="1"
                                    CornerRadius="2"/>
                        </Canvas>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="2"
                          Classes="ShellColumnSplitter"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          IsVisible="{Binding IsAssetsPanelVisible}"
                          IsHitTestVisible="{Binding IsAssetsPanelVisible}"
                          PointerReleased="OnAssetsPanelSplitterPointerReleased"/>

            <Border Grid.Column="3"
                    Background="{DynamicResource ShellWorkspaceBrush}"
                    BorderBrush="{DynamicResource ShellBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="0">
                <Border.ContextFlyout>
                    <ui:FAMenuFlyout FlyoutPresenterClasses="workspace-root-context-flyout">
                        <ui:MenuFlyoutItem Text="操作"
                                          IsEnabled="False"
                                          Classes="WorkspaceContextTitleItem"/>
                        <ui:MenuFlyoutSeparator/>
                        <ui:MenuFlyoutItem Text="新建标签"
                                          Classes="WorkspaceContextActionItem"
                                          Command="{Binding CreateWorkspaceTabCommand}">
                            <ui:MenuFlyoutItem.IconSource>
                                <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE710;"/>
                            </ui:MenuFlyoutItem.IconSource>
                        </ui:MenuFlyoutItem>
                        <ui:MenuFlyoutItem Text="关闭当前标签"
                                          Classes="WorkspaceContextActionItem"
                                          Command="{Binding CloseTabCommand}"
                                          CommandParameter="{x:Null}">
                            <ui:MenuFlyoutItem.IconSource>
                                <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE711;"/>
                            </ui:MenuFlyoutItem.IconSource>
                        </ui:MenuFlyoutItem>
                        <ui:MenuFlyoutSeparator/>
                        <ui:MenuFlyoutItem Text="关闭其他标签"
                                          Classes="WorkspaceContextActionItem"
                                          Command="{Binding CloseOtherTabsCommand}"
                                          CommandParameter="{x:Null}">
                            <ui:MenuFlyoutItem.IconSource>
                                <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE74D;"/>
                            </ui:MenuFlyoutItem.IconSource>
                        </ui:MenuFlyoutItem>
                        <ui:MenuFlyoutItem Text="关闭全部标签"
                                          Classes="WorkspaceContextActionItem"
                                          Command="{Binding CloseAllTabsCommand}">
                            <ui:MenuFlyoutItem.IconSource>
                                <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE8BB;"/>
                            </ui:MenuFlyoutItem.IconSource>
                        </ui:MenuFlyoutItem>
                        <ui:MenuFlyoutSeparator/>
                        <ui:MenuFlyoutItem Text="显示 Snippets"
                                          Classes="WorkspaceContextActionItem"
                                          Command="{Binding ShowSnippetsToolsCommand}">
                            <ui:MenuFlyoutItem.IconSource>
                                <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE8D2;"/>
                            </ui:MenuFlyoutItem.IconSource>
                        </ui:MenuFlyoutItem>
                        <ui:MenuFlyoutItem Text="显示 History"
                                          Classes="WorkspaceContextActionItem"
                                          Command="{Binding ShowHistoryToolsCommand}">
                            <ui:MenuFlyoutItem.IconSource>
                                <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE81C;"/>
                            </ui:MenuFlyoutItem.IconSource>
                        </ui:MenuFlyoutItem>
                        <ui:MenuFlyoutItem Text="显示 SFTP"
                                          Classes="WorkspaceContextActionItem"
                                          Command="{Binding ShowSftpToolsCommand}">
                            <ui:MenuFlyoutItem.IconSource>
                                <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE8B7;"/>
                            </ui:MenuFlyoutItem.IconSource>
                        </ui:MenuFlyoutItem>
                    </ui:FAMenuFlyout>
                </Border.ContextFlyout>
                <Grid>
                    <views:WorkspaceHost/>
                    <views:WorkspaceDragOverlay/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="4"
                          Classes="ShellColumnSplitter"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          PointerReleased="OnRightSidebarSplitterPointerReleased"
                          IsVisible="{Binding IsRightSidebarVisible}"
                          IsHitTestVisible="{Binding IsRightSidebarVisible}"/>

            <Border Grid.Column="5"
                    MinWidth="120"
                    IsVisible="{Binding IsRightSidebarVisible}"
                    Background="{DynamicResource ShellToolsBrush}"
                    BorderBrush="{DynamicResource ShellBorderBrush}"
                    BorderThickness="0"
                    CornerRadius="0">
                <Border.ContextFlyout>
                    <ui:FAMenuFlyout FlyoutPresenterClasses="tools-root-context-flyout">
                        <ui:MenuFlyoutItem Text="操作"
                                          IsEnabled="False"
                                          Classes="ToolsContextTitleItem"/>
                        <ui:MenuFlyoutSeparator/>
                        <ui:MenuFlyoutItem Text="切换到 Snippets"
                                          Classes="ToolsContextActionItem"
                                          Command="{Binding ShowSnippetsToolsCommand}">
                            <ui:MenuFlyoutItem.IconSource>
                                <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE8D2;"/>
                            </ui:MenuFlyoutItem.IconSource>
                        </ui:MenuFlyoutItem>
                        <ui:MenuFlyoutItem Text="切换到 History"
                                          Classes="ToolsContextActionItem"
                                          Command="{Binding ShowHistoryToolsCommand}">
                            <ui:MenuFlyoutItem.IconSource>
                                <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE81C;"/>
                            </ui:MenuFlyoutItem.IconSource>
                        </ui:MenuFlyoutItem>
                        <ui:MenuFlyoutItem Text="切换到 SFTP"
                                          Classes="ToolsContextActionItem"
                                          Command="{Binding ShowSftpToolsCommand}">
                            <ui:MenuFlyoutItem.IconSource>
                                <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE8B7;"/>
                            </ui:MenuFlyoutItem.IconSource>
                        </ui:MenuFlyoutItem>
                        <ui:MenuFlyoutSeparator/>
                        <ui:MenuFlyoutItem Text="隐藏工具栏"
                                          Classes="ToolsContextActionItem"
                                          Command="{Binding ToggleRightSidebarCommand}">
                            <ui:MenuFlyoutItem.IconSource>
                                <ui:FontIconSource FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Glyph="&#xE76B;"/>
                            </ui:MenuFlyoutItem.IconSource>
                        </ui:MenuFlyoutItem>
                    </ui:FAMenuFlyout>
                </Border.ContextFlyout>
                <views:RightSidebarHostView/>
            </Border>
        </Grid>
    </Grid>

</Window>
