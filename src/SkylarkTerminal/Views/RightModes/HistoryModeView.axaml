<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:SkylarkTerminal.Models"
             xmlns:views="using:SkylarkTerminal.Views"
             x:Class="SkylarkTerminal.Views.RightModes.HistoryModeView"
             x:CompileBindings="False">
    <ListBox ItemsSource="{Binding DataContext.HistoryItems, RelativeSource={RelativeSource AncestorType=views:RightSidebarHostView}}">
        <ListBox.ItemTemplate>
            <DataTemplate DataType="models:CommandHistoryEntry">
                <Grid ColumnDefinitions="Auto,*"
                      Margin="0">
                    <TextBlock Opacity="0.72"
                               FontFamily="Consolas"
                               Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"/>
                    <TextBlock Grid.Column="1"
                               Margin="4,0,0,0"
                               Text="{Binding Command}"/>
                </Grid>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
