<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:SkylarkTerminal.Models"
             xmlns:views="using:SkylarkTerminal.Views"
             x:Class="SkylarkTerminal.Views.RightModes.SftpModeView"
             x:CompileBindings="False">
    <ListBox ItemsSource="{Binding DataContext.SftpItems, RelativeSource={RelativeSource AncestorType=views:RightSidebarHostView}}">
        <ListBox.ItemTemplate>
            <DataTemplate DataType="models:RemoteFileNode">
                <Grid ColumnDefinitions="*,Auto"
                      Margin="0">
                    <TextBlock Text="{Binding Name}"/>
                    <TextBlock Grid.Column="1"
                               Opacity="0.72"
                               Text="{Binding FullPath}"/>
                </Grid>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
